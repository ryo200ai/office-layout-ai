# Anthropic APIキー
# https://console.anthropic.com/ で取得してください
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CTAボタンのリンク先URL（問い合わせフォームや予約ページのURLを設定）
NEXT_PUBLIC_CTA_URL=https://example.com/contact

# Resend APIキー（メール送信に使用）
# https://resend.com/ で無料アカウントを作成して取得してください
# 未設定の場合はメール送信がスキップされます
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
